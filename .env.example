# ===========================================
# TILMS - Minimal .env Configuration
# ===========================================
# Only infrastructure variables go here.
# Everything else is configured via Admin Panel:
#   - API Keys (Claude, Razorpay, Resend, GitHub)
#   - Email from address & name
#   - Platform branding (name, logo, theme)
#   - Certificate signatory
#   - AI model selection
#   - Payment environment (test/live)
# ===========================================

APP_NAME=TILMS
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-app.laravel.cloud

# Database (Laravel Cloud auto-injects DB_HOST, DB_DATABASE, DB_USERNAME, DB_PASSWORD)
DB_CONNECTION=mysql

# Session, Cache, Queue
SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database

# Mail driver (API key configured via Admin Panel > Settings > API Keys)
MAIL_MAILER=resend

# Filesystem
FILESYSTEM_DISK=local

# Vite
VITE_APP_NAME="${APP_NAME}"
